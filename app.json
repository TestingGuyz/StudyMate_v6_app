{
  "expo": {
    "name": "StudyMate AI",
    "slug": "studymate-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "studymate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070235"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studymate.ai"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070235"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.studymate.ai"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow StudyMate AI to access your camera for scanning questions."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow StudyMate AI to access your photos for scanning answers."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
